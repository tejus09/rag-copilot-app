# Copy to .env and adjust as needed. All values shown are the defaults.

# Ollama model used for answering questions (must be `ollama pull`ed first)
OLLAMA_MODEL=qwen2.5-coder:1.5b

# HuggingFace sentence-transformers model used for embeddings
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Chunking
CHUNK_SIZE=1500
CHUNK_OVERLAP=200

# Number of chunks retrieved per question
RETRIEVER_K=5

# Where cloned repos, the vector DB, and the cached embedding model are stored
DATA_DIR=data
VECTOR_DB_DIR=vector_db
LOCAL_MODELS_DIR=local_models
